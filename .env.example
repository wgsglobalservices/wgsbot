# minutesbot deployment configuration (non-secret values only).
#
# Copy to .env and fill in your values. `pnpm setup:cloudflare` reads this
# file for defaults when patching wrangler.jsonc; the values here are also
# read by `pnpm check` for post-deploy health checks.

# Cloudflare account to deploy into. Only needed when your wrangler login can
# access more than one account. Account ids are intentionally never checked
# into source; wrangler reads this variable directly.
CLOUDFLARE_ACCOUNT_ID=

# Public base URLs. The first three are custom domains on the main minutesbot
# Worker; BOT_API_BASE_URL is the custom domain of the separate bot container
# worker (minutesbot-meeting-bot).
# Cloudflare Workers Builds default to minutes.bot; set MINUTESBOT_DOMAIN to
# derive these values from a different zone, or set the explicit URLs below.
MINUTESBOT_DOMAIN=minutes.bot
APP_BASE_URL=https://app.example.com
API_BASE_URL=https://api.example.com
BOT_WEBHOOK_BASE_URL=https://meeting.example.com
BOT_API_BASE_URL=https://meeting-api.example.com

# Mailbox that receives Teams meeting invites via Cloudflare Email Routing.
# Also used as the recap sender address by default.
RECORDER_EMAIL=notetaker@example.com

# Admin auth mode. Default (false): Cloudflare Access protects the admin UI
# and API (set CLOUDFLARE_ACCESS_AUD / CLOUDFLARE_ACCESS_JWKS_URL /
# CLOUDFLARE_ACCESS_ISSUER as wrangler vars). Set to "true" only for
# development-style deployments that authenticate with a static admin token
# (SESSION_SECRET).
ALLOW_ADMIN_TOKEN_AUTH=false

# Optional: admin token used by `pnpm check` to exercise the authed R2
# round-trip endpoint (/api/admin/test-r2). Only meaningful in admin-token
# auth mode, where it must equal the SESSION_SECRET secret.
MINUTESBOT_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# SECRETS — never put these in .env or any file. Set them with wrangler:
#
#   wrangler secret put AI_API_KEY            # OpenAI(-compatible) API key for recap
#                                             # generation (gpt-5.5 default); also used
#                                             # for Whisper transcription unless
#                                             # TRANSCRIPTION_API_KEY is set
#   wrangler secret put TRANSCRIPTION_API_KEY # optional: separate key for a
#                                             # whisper-compatible endpoint
#   wrangler secret put SESSION_SECRET        # admin token (admin-token auth mode only)
#
# BOT_INTERNAL_TOKEN (signed bot webhooks + runtime API auth) is generated and
# pushed to both workers automatically by `pnpm bot:deploy` — do not set it
# by hand and do not store it anywhere.
# ---------------------------------------------------------------------------
